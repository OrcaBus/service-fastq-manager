<mxfile host="app.diagrams.net" modified="2026-07-21T00:00:00.000Z" agent="draw.io" version="24.0.0" type="device">
  <diagram id="somalier-extract" name="Somalier Extract">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Start -->
        <mxCell id="n1" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a1a1a;fontSize=13;fontFamily=Segoe UI;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="100" y="30" width="56" height="36" as="geometry" />
        </mxCell>
        <!-- Resolve references -->
        <mxCell id="n2" value="&lt;b&gt;Resolve reference paths&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;color:#555555;font-size:11px&quot;&gt;Genome + sites VCF from SSM&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="0" y="110" width="300" height="62" as="geometry" />
        </mxCell>
        <!-- Has BAM? -->
        <mxCell id="n3" value="BAM URI&lt;br&gt;provided?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="30" y="220" width="240" height="62" as="geometry" />
        </mxCell>
        <!-- Get fastq list + decompress if ORA -->
        <mxCell id="n4" value="&lt;b&gt;Get fastq list from set&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;color:#555555;font-size:11px&quot;&gt;Decompress if ORA (wait for callback)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="0" y="330" width="300" height="62" as="geometry" />
        </mxCell>
        <!-- Generate fingerprint + mini-BAM -->
        <mxCell id="n5" value="&lt;b&gt;Generate fingerprint + mini-BAM&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;color:#555555;font-size:11px&quot;&gt;Align to sites, extract somalier&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="0" y="440" width="300" height="62" as="geometry" />
        </mxCell>
        <!-- Get metadata -->
        <mxCell id="n6" value="&lt;b&gt;Get library/individual metadata&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="575" y="110" width="300" height="62" as="geometry" />
        </mxCell>
        <!-- Send to Holmes -->
        <mxCell id="n7" value="&lt;b&gt;Send mini-BAM to Holmes&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;color:#555555;font-size:11px&quot;&gt;Trigger Holmes extract state machine&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="575" y="220" width="300" height="62" as="geometry" />
        </mxCell>
        <!-- Update fastq set -->
        <mxCell id="n8" value="&lt;b&gt;Update fastq set record&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;color:#555555;font-size:11px&quot;&gt;Persist somalier URI&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="575" y="330" width="300" height="62" as="geometry" />
        </mxCell>
        <!-- Success -->
        <mxCell id="n10" value="Success" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="625" y="440" width="200" height="46" as="geometry" />
        </mxCell>
        <!-- Failure -->
        <mxCell id="n11" value="Failure" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="920" y="118" width="120" height="46" as="geometry" />
        </mxCell>
        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n1" target="n2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n2" target="n3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- no BAM -> get fastq list -->
        <mxCell id="e3" value="no" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n3" target="n4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- yes BAM -> generate directly (skip to n5) -->
        <mxCell id="e3b" value="yes" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#888888;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="n3" target="n5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="320" y="251" />
              <mxPoint x="320" y="471" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- get fastq list -> generate -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n4" target="n5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- generate -> get metadata (cross-column) -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n5" target="n6">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="150" y="540" />
              <mxPoint x="450" y="540" />
              <mxPoint x="450" y="80" />
              <mxPoint x="725" y="80" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- generate -> failure (catch) -->
        <mxCell id="e5b" value="failed" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="n6" target="n11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- metadata -> Holmes -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n6" target="n7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Holmes -> update set -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n7" target="n8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- update set -> success -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n8" target="n10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
